---
import '../styles/global.css';
import { SITE } from '../lib/site';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'instead. — open-source alternatives',
  description = 'Free, privacy-first, open-source alternatives to popular apps and services.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="color-scheme" content="dark light" />
    <meta name="referrer" content="no-referrer" />
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 32 32%22><text y=%2224%22 font-size=%2228%22>i.</text></svg>" />
    <title>{title}</title>
  </head>
  <body>
    <header class="wrap" style="padding-top:24px; padding-bottom:24px; display:flex; align-items:center; justify-content:space-between;">
      <a href="/" aria-label="instead. home" style="font-weight:500; letter-spacing:-0.01em;">
        instead<span class="accent">.</span>
      </a>
      <a
        href={SITE.repoUrl}
        rel="noopener noreferrer"
        aria-label="GitHub repository"
        style="display:inline-flex; align-items:center; color:var(--muted);"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56v-2c-3.2.7-3.87-1.36-3.87-1.36-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.68 1.24 3.34.95.1-.74.4-1.24.72-1.53-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.46.11-3.05 0 0 .96-.31 3.16 1.18a10.92 10.92 0 0 1 5.75 0c2.2-1.49 3.16-1.18 3.16-1.18.62 1.59.23 2.76.11 3.05.74.81 1.18 1.84 1.18 3.1 0 4.42-2.69 5.39-5.25 5.68.41.36.78 1.06.78 2.13v3.16c0 .31.21.67.8.55C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z"/>
        </svg>
      </a>
    </header>
    <main class="wrap">
      <slot />
    </main>
    <footer class="wrap" style="padding-top:48px; padding-bottom:32px; color:var(--muted); font-size:14px;">
      <a href={SITE.repoUrl} rel="noopener noreferrer">GitHub</a>
      <span style="margin:0 8px;">·</span>
      <a href="/submit">Submit</a>
      <span style="margin:0 8px;">·</span>
      <a href="/about">About</a>
    </footer>
  </body>
</html>

<style is:global>
  html { scroll-behavior: smooth; }
</style>
